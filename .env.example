# =============================================================================
# Budgety environment variables (template — no real secrets)
# =============================================================================
#
# Local development:
#   cp .env.example .env.local
#   Fill in values in .env.local (gitignored)
#
# Vercel production / preview:
#   Set secrets in the Vercel dashboard or: npx vercel env pull .env.local
#   See docs/VERCEL_ENV.md
#
# =============================================================================

# --- Required (server) ---

# Neon PostgreSQL — use the POOLED connection string on Vercel/serverless
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Better Auth — min 32 characters (generate: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# --- Recommended for production (Vercel) ---

# Public app URL for auth callbacks (server)
# Production: https://budgety-woad.vercel.app
# Local: http://localhost:3000
# BETTER_AUTH_URL=

# Same URL for the browser auth client (safe to expose — not a secret)
# NEXT_PUBLIC_BETTER_AUTH_URL=
