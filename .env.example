# Current/source Neon database (existing data)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# New budgety-store database (create in Neon, then run scripts)
# 1. In Neon: create branch or project named "budgety-store", copy connection string
# 2. BUDGETY_STORE_DATABASE_URL=postgresql://... node scripts/init-budgety-store-db.js
# 3. DATABASE_URL=... BUDGETY_STORE_DATABASE_URL=... node scripts/migrate-to-budgety-store.js
# 4. Switch app to new DB: set DATABASE_URL to BUDGETY_STORE_DATABASE_URL value
BUDGETY_STORE_DATABASE_URL=postgresql://user:password@host/budgety-store?sslmode=require
