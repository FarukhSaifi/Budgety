{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@api/*": [
        "./src/api/*"
      ],
      "@api": [
        "./src/api"
      ],
      "@ui/*": [
        "./src/components/ui/*"
      ],
      "@components/*": [
        "./src/components/*"
      ],
      "@lib/*": [
        "./src/*"
      ],
      "@hooks/*": [
        "./src/hooks/*"
      ],
      "@context/*": [
        "./src/context/*"
      ],
      "@context": [
        "./src/context"
      ],
      "@constants/*": [
        "./src/constants/*"
      ],
      "@constants": [
        "./src/constants"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@utils": [
        "./src/utils"
      ],
      "@theme/*": [
        "./src/theme/*"
      ],
      "@theme": [
        "./src/theme"
      ]
    }
  },
  "include": [
    "src",
    "next.config.js"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out"
  ]
}